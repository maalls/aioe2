# Required — HuggingFace token for pyannote.audio
# 1. Sign up at https://huggingface.co
# 2. Accept model terms at https://huggingface.co/pyannote/speaker-diarization-3.1
# 3. Generate a token at https://huggingface.co/settings/tokens (read access)
HF_TOKEN=hf_your_token_here

# Optional — override compute device: cpu | mps | cuda (auto-detected if unset)
# TRANSCRIBER_DEVICE=cpu
